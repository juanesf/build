diff --git a/drivers/net/ethernet/stmicro/stmmac/dwmac-sunxi-200.c b/drivers/net/ethernet/stmicro/stmmac/dwmac-sunxi-200.c
new file mode 100644
index 000000000..a7a4d3c71
--- /dev/null
+++ b/drivers/net/ethernet/stmicro/stmmac/dwmac-sunxi-200.c
@@ -0,0 +1,434 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/* Copyright(c) 2020 - 2023 Allwinner Technology Co.,Ltd. All rights reserved. */
+/*
+* Allwinner DWMAC driver.
+*
