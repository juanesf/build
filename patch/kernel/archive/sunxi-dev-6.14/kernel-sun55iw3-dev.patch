From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juan Sanchez <juanesf91@gmail.com>
Date: Wed, 23 Apr 2025 22:07:25 -0400
Subject: Add eth0/1 syscon alias leds wifi(mmc1)
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
 arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts

Signed-off-by: Juan Sanchez <juanesf91@gmail.com>
---
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi          | 35 ++--
 arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts | 89 ++++++++++
 2 files changed, 112 insertions(+), 12 deletions(-)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index ddc97f6dd022..3d13d2ac8f7f 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -142,28 +142,30 @@ pio: pinctrl@2000000 {
 			gpio-controller;
 			#gpio-cells = <3>;
 			interrupt-controller;
 			#interrupt-cells = <3>;
 
-			emac0_pins: emac0-pins {
+			rgmii0_pins: rgmii0-pins {
 				pins = "PH0", "PH1", "PH2", "PH3", "PH4",
 				       "PH5", "PH6", "PH7", "PH9", "PH10",
 				       "PH13", "PH14", "PH15", "PH16", "PH17",
 				       "PH18";
 				allwinner,pinmux = <5>;
 				function = "emac0";
 				drive-strength = <40>;
+				bias-pull-up;
 			};
 
-			emac1_pins: emac1-pins {
+			rgmii1_pins: rgmii1-pins {
 				pins = "PJ0", "PJ1", "PJ2", "PJ3", "PJ4",
 				       "PJ5", "PJ6", "PJ7", "PJ8", "PJ9",
-				       "PJ10", "PJ11","PJ12","PJ13", "PJ14",
+				       "PJ10", "PJ11", "PJ12", "PJ13", "PJ14",
 				       "PJ15";
 				allwinner,pinmux = <5>;
 				function = "emac1";
 				drive-strength = <40>;
+				bias-pull-up;
 			};
 
 			mmc0_pins: mmc0-pins {
 				pins = "PF0" ,"PF1", "PF2", "PF3", "PF4", "PF5";
 				allwinner,pinmux = <2>;
@@ -480,10 +482,18 @@ i2c5: i2c@2503400 {
 			status = "disabled";
 			#address-cells = <1>;
 			#size-cells = <0>;
 		};
 
+		syscon: syscon@3000000 {
+			compatible = "allwinner,sun50i-a64-system-control";
+			reg = <0x03000000 0x1000>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+		};
+
 		gic: interrupt-controller@3400000 {
 			compatible = "arm,gic-v3";
 			#address-cells = <1>;
 			#interrupt-cells = <3>;
 			#size-cells = <1>;
@@ -592,45 +602,46 @@ ohci1: usb@4200400 {
 			phys = <&usbphy 1>;
 			phy-names = "usb";
 			status = "disabled";
 		};
 
-		/* TODO: miss syscon node, maybe work, but don't have device to check
 		emac0: ethernet@4500000 {
 			compatible = "allwinner,sun50i-h616-emac0",
 				     "allwinner,sun50i-a64-emac";
 			reg = <0x04500000 0x10000>;
-			interrupts = <GIC_SPI 46 IRQ_TYPE_LEVEL_HIGH>;
-			interrupt-names = "macirq";
-			clocks = <&ccu CLK_BUS_EMAC0>,
-				 <&ccu CLK_EMAC0_25M>;
-			clock-names = "stmmaceth","emac_25m";
+			clocks = <&ccu CLK_BUS_EMAC0>;
+			clock-names = "stmmaceth";
 			resets = <&ccu RST_BUS_EMAC0>;
 			reset-names = "stmmaceth";
+			interrupts = <GIC_SPI 46 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			pinctrl-names = "default";
+			pinctrl-0 = <&rgmii0_pins>;
 			syscon = <&syscon>;
 			status = "disabled";
 
 			mdio0: mdio {
 				compatible = "snps,dwmac-mdio";
 				#address-cells = <1>;
 				#size-cells = <0>;
 			};
 		};
-		*/
 
 		emac1: ethernet@4510000 {
 			compatible = "allwinner,sunxi-gmac-200",
 				     "snps,dwmac-4.20a";
 			reg = <0x04510000 0x10000>,
 				 <0x03000034 0x4>;
-			interrupts = <GIC_SPI 47 IRQ_TYPE_LEVEL_HIGH>;
-			interrupt-names = "macirq";
 			clocks = <&ccu CLK_BUS_EMAC1>, <&ccu CLK_MBUS_EMAC1>,
 				 <&ccu CLK_EMAC1_25M>;
 			clock-names = "stmmaceth", "pclk", "phy25m";
 			resets = <&ccu RST_BUS_EMAC1>;
 			reset-names = "stmmaceth";
+			interrupts = <GIC_SPI 47 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			pinctrl-names = "default";
+			pinctrl-0 = <&rgmii1_pins>;
 			snps,fixed-burst;
 			snps,axi-config = <&emac1_stmmac_axi_setup>;
 			snps,mtl-rx-config = <&emac1_mtl_rx_setup>;
 			snps,mtl-tx-config = <&emac1_mtl_tx_setup>;
 			status = "disabled";
diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts b/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
index 13e476c0c997..373b11b506f2 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
@@ -12,16 +12,37 @@ / {
 	model = "Radxa A5E";
 	compatible = "radxa,cubie-a5e", "allwinner,sun55i-a527";
 
 	aliases {
 		serial0 = &uart0;
+		mmc0 = &mmc0;
+		mmc1 = &mmc1;
+		ethernet0 = &emac0;
+		ethernet1 = &emac1;
+		ethernet2 = &wlan;
 	};
 
 	chosen {
 		stdout-path = "serial0:115200n8";
 	};
 
+	leds {
+		compatible = "gpio-leds";
+
+		led-0 {
+			label = "radxa:green:power";
+			gpios = <&r_pio 0 4 GPIO_ACTIVE_LOW>; /* PL4 */
+			linux,default-trigger = "heartbeat";
+		};
+
+		led-1 {
+			label = "radxa:blue:user";
+			gpios = <&r_pio 0 5 GPIO_ACTIVE_LOW>; /* PL5 */
+			linux,default-trigger = "default-on";
+		};
+	};
+
 	ext_osc32k: ext-osc32k-clk {
 		#clock-cells = <0>;
 		compatible = "fixed-clock";
 		clock-frequency = <32768>;
 		clock-output-names = "ext_osc32k";
@@ -43,10 +64,20 @@ reg_usb_vbus: vbus {
 		regulator-max-microvolt = <5000000>;
 		vin-supply = <&reg_vcc5v>;
 		gpio = <&r_pio 0 8 GPIO_ACTIVE_HIGH>;	/* PL8 */
 		enable-active-high;
 	};
+
+	reg_3v3_wifi: 3v3-wifi {
+		compatible = "regulator-fixed";
+		regulator-name = "3v3-wifi";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		vin-supply = <&reg_vcc5v>;
+		gpio = <&r_pio 0 7 GPIO_ACTIVE_HIGH>; /* PL7 */
+		enable-active-high;
+	};
 };
 
 &cpu0 {
 	cpu-supply = <&reg_dcdc1>;
 };
@@ -61,17 +92,75 @@ &ehci0 {
 
 &ehci1 {
 	status = "okay";
 };
 
+&emac0 {
+	phy-mode = "rgmii-id";
+	phy-handle = <&ext_rgmii_phy0>;
+	phy-supply = <&reg_cldo3>;
+
+	allwinner,tx-delay-ps = <300>;
+	allwinner,rx-delay-ps = <400>;
+
+	status = "okay";
+};
+
+&emac1 {
+	phy-mode = "rgmii-id";
+	phy-handle = <&ext_rgmii_phy1>;
+	aw,soc-phy25m;
+	tx-delay = <300>;
+	rx-delay = <400>;
+	dwmac3v3-supply = <&reg_cldo3>;
+	snps,reset-gpio = <&pio 9 16 GPIO_ACTIVE_LOW>;
+	snps,reset-delays-us = <0>, <10000>, <150000>;
+	snps,reset-active-low;
+	status = "okay";
+};
+
+&mdio0 {
+	ext_rgmii_phy0: ethernet-phy@1 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <1>;
+	};
+};
+
+&mdio1 {
+	ext_rgmii_phy1: ethernet-phy@1 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <1>;
+		reset-assert-us = <10000>;
+		reset-deassert-us = <150000>;
+		reset-gpios = <&pio 9 16 GPIO_ACTIVE_LOW>;
+	};
+};
+
 &mmc0 {
 	vmmc-supply = <&reg_cldo3>;
 	cd-gpios = <&pio 5 6 (GPIO_ACTIVE_LOW | GPIO_PULL_DOWN)>; /* PF6 */
 	bus-width = <4>;
 	status = "okay";
 };
 
+&mmc1 {
+	vmmc-supply = <&reg_3v3_wifi>;
+	bus-width = <4>;
+	non-removable;
+	// todo: investigate why clock above 40MHz makes data errors
+	max-frequency = <35000000>;
+	status = "okay";
+
+	wlan: wifi@1 {
+		reg = <1>;
+	};
+};
+
+&mmc1_pins {
+	drive-strength = <40>;
+};
+
 &ohci0 {
 	status = "okay";
 };
 
 &ohci1 {
