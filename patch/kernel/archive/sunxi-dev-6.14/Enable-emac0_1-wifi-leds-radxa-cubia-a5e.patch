From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: John Doe <john.doe@somewhere.on.planet>
Date: Fri, 18 Apr 2025 23:23:55 -0400
Subject: Enable emac0/1 wifi leds radxa-a5e.dts

Signed-off-by: John Doe <john.doe@somewhere.on.planet>
---
 arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts | 96 ++++++++++
 1 file changed, 96 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts b/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
index 13e476c0c997..356dd118aee5 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a527-radxa-a5e.dts
@@ -12,16 +12,37 @@ / {
 	model = "Radxa A5E";
 	compatible = "radxa,cubie-a5e", "allwinner,sun55i-a527";
 
 	aliases {
 		serial0 = &uart0;
+		mmc0 = &mmc0;
+		mmc1 = &mmc1;
+		ethernet0 = &emac0;
+		ethernet1 = &emac1;
+		ethernet2 = &wlan;
 	};
 
 	chosen {
 		stdout-path = "serial0:115200n8";
 	};
 
+	leds {
+		compatible = "gpio-leds";
+
+		led-0 {
+			label = "radxa:green:power";
+			gpios = <&r_pio 0 4 GPIO_ACTIVE_LOW>; /* PL4 */
+			linux,default-trigger = "heartbeat";
+		};
+
+		led-1 {
+			label = "radxa:blue:user";
+			gpios = <&r_pio 0 5 GPIO_ACTIVE_LOW>; /* PL5 */
+			linux,default-trigger = "default-on";
+		};
+	};
+
 	ext_osc32k: ext-osc32k-clk {
 		#clock-cells = <0>;
 		compatible = "fixed-clock";
 		clock-frequency = <32768>;
 		clock-output-names = "ext_osc32k";
@@ -43,10 +64,20 @@ reg_usb_vbus: vbus {
 		regulator-max-microvolt = <5000000>;
 		vin-supply = <&reg_vcc5v>;
 		gpio = <&r_pio 0 8 GPIO_ACTIVE_HIGH>;	/* PL8 */
 		enable-active-high;
 	};
+
+	reg_3v3_wifi: 3v3-wifi {
+		compatible = "regulator-fixed";
+		regulator-name = "3v3-wifi";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		vin-supply = <&reg_vcc5v>;
+		gpio = <&r_pio 0 7 GPIO_ACTIVE_HIGH>; /* PL7 */
+		enable-active-high;
+	};
 };
 
 &cpu0 {
 	cpu-supply = <&reg_dcdc1>;
 };
@@ -68,10 +99,27 @@ &mmc0 {
 	cd-gpios = <&pio 5 6 (GPIO_ACTIVE_LOW | GPIO_PULL_DOWN)>; /* PF6 */
 	bus-width = <4>;
 	status = "okay";
 };
 
+&mmc1_pins {
+	drive-strength = <40>;
+};
+
+&mmc1 {
+	vmmc-supply = <&reg_3v3_wifi>;
+	bus-width = <4>;
+	non-removable;
+	// todo: investigate why clock above 40MHz makes data errors
+	max-frequency = <35000000>;
+	status = "okay";
+
+	wlan: wifi@1 {
+		reg = <1>;
+	};
+};
+
 &ohci0 {
 	status = "okay";
 };
 
 &ohci1 {
@@ -304,5 +352,53 @@ &usb_otg {
 &usbphy {
 	usb0_vbus-supply = <&reg_vcc5v>;
 	usb1_vbus-supply = <&reg_usb_vbus>;
 	status = "okay";
 };
+
+&emac0 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&emac0_pins>;
+
+	phy-mode = "rgmii";
+	phy-handle = <&ext_rgmii_phy>;
+	phy-supply = <&reg_cldo3>;
+
+	allwinner,tx-delay-ps =  < 300 >;
+	allwinner,rx-delay-ps =  < 400 >;
+
+	status = "okay";
+};
+
+&mdio0 {
+	ext_rgmii_phy: ethernet-phy@1 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <1>;
+	};
+};
+
+&emac1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&emac1_pins>;
+	phy-handle = <&emac1_phy>;
+	phy-mode = "rgmii";
+	aw,soc-phy25m;
+	tx-delay = <3>;
+	rx-delay = <4>;
+	dwmac3v3-supply = <&reg_cldo3>;
+	snps,reset-gpio = <&pio 9 16 GPIO_ACTIVE_LOW>;
+	snps,reset-delays-us = <0>, <10000>, <150000>;
+	snps,reset-active-low;
+	status = "okay";
+};
+
+&mdio1 {
+	emac1_phy: ethernet-phy@1 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <0x1>;
+		/* TODO: doesn't work?
+		reset-assert-us = <10000>;
+		reset-deassert-us = <150000>;
+		reset-gpios = <&pio 9 16 GPIO_ACTIVE_LOW>;
+		*/
+	};
+};
-- 
