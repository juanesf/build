From f1fbb321b5871f5d77cb24d36c1fb02b12e0a30c Mon Sep 17 00:00:00 2001
From: iuncuim <iuncuim@gmail.com>
Date: Mon, 7 Apr 2025 03:26:40 +0300
Subject: [PATCH 2/2] arm64: dts: allwinner: add emac1 support for x96qpro+

Signed-off-by: Mikhail Kalashnikov <iuncuim@gmail.com>
---
 .../arm64/boot/dts/allwinner/sun55i-a523.dtsi | 84 +++++++++++++++++++
 .../dts/allwinner/sun55i-h728-x96qpro+.dts    | 27 ++++++
 2 files changed, 111 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index ad3722b5c..f7697a31f 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -134,6 +134,26 @@ pio: pinctrl@2000000 {
 			interrupt-controller;
 			#interrupt-cells = <3>;
 
+			emac0_pins: emac0-pins {
+				pins = "PH0", "PH1", "PH2", "PH3", "PH4",
+				       "PH5", "PH6", "PH7", "PH9", "PH10",
+				       "PH13", "PH14", "PH15", "PH16", "PH17",
+				       "PH18";
+				allwinner,pinmux = <5>;
+				function = "emac0";
+				drive-strength = <40>;
+			};
+
+			emac1_pins: emac1-pins {
+				pins = "PJ0", "PJ1", "PJ2", "PJ3", "PJ4",
+				       "PJ5", "PJ6", "PJ7", "PJ8", "PJ9",
+				       "PJ10", "PJ11","PJ12","PJ13", "PJ14",
+				       "PJ15";
+				allwinner,pinmux = <5>;
+				function = "emac1";
+				drive-strength = <40>;
+			};
+
 			mmc0_pins: mmc0-pins {
 				pins = "PF0" ,"PF1", "PF2", "PF3", "PF4", "PF5";
 				allwinner,pinmux = <2>;
@@ -563,6 +583,70 @@ ohci1: usb@4200400 {
 			status = "disabled";
 		};
 
+		/* TODO: miss syscon node, maybe work, but don't have device to check
+		emac0: ethernet@4500000 {
+			compatible = "allwinner,sun50i-h616-emac0",
+				     "allwinner,sun50i-a64-emac";
+			reg = <0x04500000 0x10000>;
+			interrupts = <GIC_SPI 46 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			clocks = <&ccu CLK_BUS_EMAC0>,
+				 <&ccu CLK_EMAC0_25M>;
+			clock-names = "stmmaceth","emac_25m";
+			resets = <&ccu RST_BUS_EMAC0>;
+			reset-names = "stmmaceth";
+			syscon = <&syscon>;
+			status = "disabled";
+
+			mdio0: mdio {
+				compatible = "snps,dwmac-mdio";
+				#address-cells = <1>;
+				#size-cells = <0>;
+			};
+		};
+		*/
+
+		emac1: ethernet@4510000 {
+			compatible = "allwinner,sunxi-gmac-200",
+				     "snps,dwmac-4.20a";
+			reg = <0x04510000 0x10000>,
+				 <0x03000034 0x4>;
+			interrupts = <GIC_SPI 47 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			clocks = <&ccu CLK_BUS_EMAC1>, <&ccu CLK_MBUS_EMAC1>,
+				 <&ccu CLK_EMAC1_25M>;
+			clock-names = "stmmaceth", "pclk", "phy25m";
+			resets = <&ccu RST_BUS_EMAC1>;
+			reset-names = "stmmaceth";
+			snps,fixed-burst;
+			snps,axi-config = <&emac1_stmmac_axi_setup>;
+			snps,mtl-rx-config = <&emac1_mtl_rx_setup>;
+			snps,mtl-tx-config = <&emac1_mtl_tx_setup>;
+			status = "disabled";
+
+			emac1_stmmac_axi_setup: stmmac-axi-config {
+				snps,wr_osr_lmt = <0xf>;
+				snps,rd_osr_lmt = <0xf>;
+				snps,blen = <256 128 64 32 16 8 4>;
+			};
+
+			emac1_mtl_rx_setup: rx-queues-config {
+				snps,rx-queues-to-use = <1>;
+				queue0 {};
+			};
+
+			emac1_mtl_tx_setup: tx_queues-config {
+				snps,tx-queues-to-use = <1>;
+				queue0 {};
+			};
+
+			mdio1: mdio {
+				compatible = "snps,dwmac-mdio";
+				#address-cells = <1>;
+				#size-cells = <0>;
+			};
+		};
+
 		r_ccu: clock-controller@7010000 {
 			compatible = "allwinner,sun55i-a523-r-ccu";
 			reg = <0x7010000 0x250>;
diff --git a/arch/arm64/boot/dts/allwinner/sun55i-h728-x96qpro+.dts b/arch/arm64/boot/dts/allwinner/sun55i-h728-x96qpro+.dts
index e0abc6353..1a973312c 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-h728-x96qpro+.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-h728-x96qpro+.dts
@@ -60,6 +60,33 @@ &ehci1 {
 	status = "okay";
 };
 
+&emac1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&rgmii1_pins>;
+	phy-handle = <&emac1_phy>;
+	phy-mode = "rgmii-id";
+	aw,soc-phy25m;
+	tx-delay = <2>;
+	rx-delay = <5>;
+	dwmac3v3-supply = <&reg_cldo3>;
+	snps,reset-gpio = <&pio 9 16 GPIO_ACTIVE_LOW>;
+	snps,reset-delays-us = <0>, <10000>, <150000>;
+	snps,reset-active-low;
+	status = "okay";
+};
+
+&mdio1 {
+	emac1_phy: ethernet-phy@1 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <0x1>;
+		/* TODO: doesn't work? 
+		reset-assert-us = <10000>;
+		reset-deassert-us = <150000>;
+		reset-gpios = <&pio 9 16 GPIO_ACTIVE_LOW>;
+		*/
+	};
+};
+
 &mmc0 {
 	vmmc-supply = <&reg_vcc3v3>;
 	cd-gpios = <&pio 5 6 (GPIO_ACTIVE_LOW | GPIO_PULL_DOWN)>; /* PF6 */
-- 
2.49.0

